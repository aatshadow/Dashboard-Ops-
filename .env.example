# ============================================
# FBA Academy Dashboard - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# These are also needed in Vercel Dashboard → Settings → Environment Variables

# Supabase (get from: supabase.com → Project → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Webhook Security (generate a random string for the API key)
WEBHOOK_API_KEY=your-secret-api-key-here

# Anthropic AI Agent (get from: console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-...your-anthropic-key

# Google Maps Places API (get from: console.cloud.google.com → APIs & Services → Credentials)
# Required for the Prospector Agent to search businesses on Google Maps
# Enable "Places API" in your Google Cloud project
GOOGLE_MAPS_API_KEY=AIza...your-google-maps-key

# Vite env vars (for the frontend to call the API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key
VITE_API_URL=https://your-app.vercel.app
